{
  "expo": {
    "name": "Green's Supermarket",
    "slug": "greens-supermarket-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#060A12"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.greenssupermarket.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to deliver groceries to you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#10b981"
      },
      "package": "com.greenssupermarket.customer",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "DETECT_SCREEN_CAPTURE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Green's Supermarket to use your location for delivery."
        }
      ]
    ],
    "scheme": "greens-supermarket",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "65ae9442-25ad-471e-897b-510d9f5a2375"
      }
    }
  }
}
