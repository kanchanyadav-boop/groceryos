rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images: public read, staff write
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.role in ['admin', 'inventory_manager']
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Delivery proofs: agent write, order parties read
    match /delivery-proofs/{orderId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Invoices: owner + billing staff
    match /invoices/{userId}/{allPaths=**} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || request.auth.token.role in ['admin', 'billing']);
      allow write: if false; // Cloud Functions only
    }
  }
}
