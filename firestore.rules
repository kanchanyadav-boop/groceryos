// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() in ['admin', 'inventory_manager', 'dispatcher', 'billing', 'support'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Products: public read, staff write ──────────────────────────────────
    match /products/{skuId} {
      allow read: if true; // Public catalog
      allow write: if isAuthenticated(); // Temporarily allow any authenticated user
    }

    // ── Inventory: staff only ───────────────────────────────────────────────
    match /inventory/{skuId} {
      allow read: if isAuthenticated(); // Temporarily allow any authenticated user
      allow write: if isAuthenticated(); // Temporarily allow any authenticated user
    }

    // ── Orders: customer owns theirs, staff can read all ────────────────────
    match /orders/{orderId} {
      allow read: if isAuthenticated(); // Temporarily allow any authenticated user
      allow create: if isAuthenticated(); // Cloud Function handles actual creation
      allow update: if isAuthenticated(); // Temporarily allow any authenticated user
    }

    // ── Users: own data only ────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true; // Allow reading for phone number lookup during login (demo mode)
      allow create: if true; // Allow user creation during signup (demo mode)
      allow update, delete: if true; // Allow updates during login (demo mode)
    }

    // ── Agents: own data + staff ────────────────────────────────────────────
    match /agents/{agentId} {
      allow read: if isAuthenticated();
      // Staff members (anyone with a staff doc) can manage agents.
      // isAdmin() uses custom claims which are not set; check Firestore staff doc instead.
      allow write: if isAuthenticated() && (
        isOwner(agentId) ||
        exists(/databases/$(database)/documents/staff/$(request.auth.uid))
      );
    }

    // ── Payments: own + billing staff ───────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuthenticated(); // Temporarily allow any authenticated user
      allow write: if false; // Cloud Functions only
    }

    // ── Refunds: own + billing staff ────────────────────────────────────────
    match /refunds/{refundId} {
      allow read: if isAuthenticated(); // Temporarily allow any authenticated user
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Temporarily allow any authenticated user
    }

    // ── Staff: admin only ───────────────────────────────────────────────────
    match /staff/{staffId} {
      allow read: if isAuthenticated(); // Allow any authenticated user to read their own staff doc
      allow write: if isAdmin();
    }

    // ── Categories: public read, admin write ────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Delivery slots: authenticated read, staff write ─────────────────────
    match /deliverySlots/{date} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    // ── Inventory logs: staff read ──────────────────────────────────────────
    match /inventoryLogs/{logId} {
      allow read: if isAuthenticated(); // Temporarily allow any authenticated user
      allow create: if isAuthenticated(); // Temporarily allow any authenticated user
      allow update, delete: if false;
    }

    // ── Chats: participants only ────────────────────────────────────────────
    match /chats/{orderId}/messages/{msgId} {
      allow read, write: if isAuthenticated(); // Restrict to order participants in production
    }

    // ── Stores: public read, staff write ────────────────────────────────────
    match /stores/{storeId} {
      allow read: if true; // Public for pincode checks
      allow write: if isAuthenticated(); // Staff only in production
    }

    // ── Settings: staff only ────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    // ── Notifications: user specific ────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
