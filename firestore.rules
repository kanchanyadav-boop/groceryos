// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaffMember() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    // ── Products: public read, staff write ──────────────────────────────────
    match /products/{skuId} {
      allow read: if true;
      allow write: if isStaffMember();
    }

    // ── Inventory: authenticated read, staff write ──────────────────────────
    match /inventory/{docId} {
      allow read: if isAuthenticated();
      allow write: if isStaffMember();
    }

    // ── Orders: customer creates/reads own; staff reads/updates all ─────────
    match /orders/{orderId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffMember()
      );
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffMember()
      );
    }

    // ── Users: authenticated read (for admin phone lookup), owner/staff write
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || isStaffMember()
      );
      allow delete: if isStaffMember();
    }

    // ── Agents: authenticated read, agent-owner or staff write ─────────────
    match /agents/{agentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        request.auth.uid == agentId || isStaffMember()
      );
    }

    // ── Payments: owner read, Cloud Functions write only ───────────────────
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffMember()
      );
      allow write: if false; // Cloud Functions only
    }

    // ── Refunds: owner creates, staff or owner reads, staff updates ─────────
    match /refunds/{refundId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffMember()
      );
      allow create: if isAuthenticated();
      allow update: if isStaffMember();
    }

    // ── Staff: any staff reads own doc; admin manages others ────────────────
    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow write: if isStaffMember();
    }

    // ── Categories: public read, staff write ────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isStaffMember();
    }

    // ── Settings (delivery slots etc): authenticated read, staff write ──────
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isStaffMember();
    }

    // ── Inventory logs: staff read, authenticated create, no update/delete ──
    match /inventoryLogs/{logId} {
      allow read: if isStaffMember();
      allow create: if isStaffMember();
      allow update, delete: if false;
    }

    // ── Chats: authenticated participants only ──────────────────────────────
    match /chats/{orderId}/messages/{msgId} {
      allow read, write: if isAuthenticated();
    }

    // ── Stores: public read, staff write ────────────────────────────────────
    match /stores/{storeId} {
      allow read: if true;
      allow write: if isStaffMember();
    }

    // ── Purchase Orders & Vendors: staff only ───────────────────────────────
    match /purchaseOrders/{poId} {
      allow read, write: if isStaffMember();
    }
    match /vendors/{vendorId} {
      allow read, write: if isStaffMember();
    }

    // ── Notifications: owner read, staff write ──────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isStaffMember()
      );
      allow write: if isStaffMember();
    }
  }
}
